# Copy to miner.env and fill in your values:
#   cp miner.env.example miner.env

# Wallet (must be registered on subnet 83)
WALLET_NAME=your-coldkey
WALLET_HOTKEY=your-hotkey

# Public axon endpoint (validators connect here)
AXON_IP=YOUR_PUBLIC_IP
AXON_PORT=8091

# Bittensor network
SUBTENSOR_NETWORK=finney
NETUID=83

# PM2 process name
MINER_NAME=miner-cliqueAI-sn83

# Optional extra CLI args (space-separated)
# MINER_EXTRA_ARGS=--logging.debug

# Competitive solver settings for subnet 83 (CliqueAI).
# Override with environment variables if needed.

# Seconds reserved before validator timeout for decode/encode/network overhead.
TIME_HEADROOM_SECONDS=0.7

# Fraction of timeout spent on initial heuristics before exact search.
HEURISTIC_FRACTION=0.25

# Graphs with at most this many nodes may use branch-and-bound when time remains.
BRANCH_BOUND_NODE_THRESHOLD=420

# Optional deterministic seed for local testing (leave empty in production).
SOLVER_SEED=
